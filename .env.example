# Database (Supabase PostgreSQL — eu-west-2 London)
# Pooled connection via PgBouncer (port 6543) — used by Prisma Client at runtime
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used only for Prisma migrations
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# Supabase (Storage & real-time — same project as DATABASE_URL)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Supabase Auth (email/password) — add Site URL + Redirect URLs in Supabase Dashboard:
#   http://localhost:3005/auth/callback
#   http://localhost:3005/auth/update-password   (optional; recovery uses callback → then this path)
#   https://your-domain.com/auth/callback
# Password recovery uses the same PKCE callback; ensure "Reset password" template redirect matches Site URL + /auth/callback?next=...
# Optional: bypass middleware + API auth for local tooling only (never in production)
# AUTH_DEV_BYPASS="true"

# Consentz API
CONSENTZ_API_URL="https://staging.consentz.com"
CONSENTZ_APPLICATION_ID="admin"
CONSENTZ_SESSION_TOKEN=""
CONSENTZ_USERNAME=""
CONSENTZ_PASSWORD=""

# SDK outbound API (`X-API-KEY` for /api/sdk/v1/*)
CONSENTZ_SDK_API_KEY=""

# Anthropic AI
ANTHROPIC_API_KEY=""

# Stripe (Billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (Transactional Email)
RESEND_API_KEY=""
EMAIL_FROM="Consentz <noreply@yourdomain.com>"

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# App
NEXT_PUBLIC_APP_URL=""
