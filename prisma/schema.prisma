generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

// ─── Models ──────────────────────────────────────────────────────────────────

model ActivityLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  actorId        String?   @map("actor_id") @db.Uuid
  actorName      String    @map("actor_name")
  actorRole      UserRole? @map("actor_role")
  action         String
  entityType     String    @map("entity_type")
  entityId       String?   @map("entity_id") @db.Uuid
  description    String
  previousValues Json?     @map("previous_values")
  newValues      Json?     @map("new_values")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  outcome        String    @default("SUCCESS")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId, action], map: "idx_activity_action")
  @@index([actorId], map: "idx_activity_actor")
  @@index([organizationId, entityType], map: "idx_activity_entity")
  @@index([organizationId], map: "idx_activity_org")
  @@index([createdAt], map: "idx_activity_time")
  @@map("activity_logs")
}

model AssessmentQuestion {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kloeId       String       @map("kloe_id") @db.Uuid
  serviceType  ServiceType  @map("service_type")
  question     String
  helpText     String?      @map("help_text")
  questionType QuestionType @default(YES_NO) @map("question_type")
  weight       Float        @default(1.0)
  sortOrder    Int          @map("sort_order")

  kloe      Kloe                 @relation(fields: [kloeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responses AssessmentResponse[]

  @@index([kloeId], map: "idx_assess_q_kloe")
  @@map("assessment_questions")
}

model AssessmentResponse {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String   @map("assessment_id") @db.Uuid
  questionId   String   @map("question_id") @db.Uuid
  answer       String
  score        Float?
  notes        String?
  evidenceIds  String[] @default([]) @map("evidence_ids")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessmentId], map: "idx_assess_resp_assessment")
  @@map("assessment_responses")
}

model Assessment {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String           @map("organization_id") @db.Uuid
  serviceType         ServiceType      @map("service_type")
  status              AssessmentStatus @default(IN_PROGRESS)
  startedBy           String           @map("started_by")
  startedAt           DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?        @map("completed_at") @db.Timestamptz(6)
  overallScore        Float?           @map("overall_score")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  version             Int              @default(1)
  isInitial           Boolean          @default(true) @map("is_initial")
  currentStep         Int              @default(1) @map("current_step")
  predictedRating     CqcRating?       @map("predicted_rating")
  totalGaps           Int?             @map("total_gaps")
  criticalGaps        Int?             @map("critical_gaps")
  highGaps            Int?             @map("high_gaps")
  mediumGaps          Int?             @map("medium_gaps")
  lowGaps             Int?             @map("low_gaps")
  estimatedTimeToGood Int?             @map("estimated_time_to_good")
  domainResults       Json?            @map("domain_results")

  responses    AssessmentResponse[]
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId], map: "idx_assessments_org")
  @@map("assessments")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id")
  userName       String?  @map("user_name")
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  action         String
  details        Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([organizationId], map: "idx_audit_org")
  @@map("audit_logs")
}

model ComplianceGap {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String      @map("organization_id") @db.Uuid
  domain           String
  kloeCode         String?     @map("kloe_code")
  regulationCode   String?     @map("regulation_code")
  title            String
  description      String
  severity         GapSeverity
  status           GapStatus   @default(OPEN)
  source           String      @default("assessment")
  assessmentId     String?     @map("assessment_id") @db.Uuid
  remediationSteps Json?       @map("remediation_steps")
  estimatedEffort  String?     @map("estimated_effort")
  dueDate          DateTime?   @map("due_date") @db.Timestamptz(6)
  resolvedAt       DateTime?   @map("resolved_at") @db.Timestamptz(6)
  resolvedById     String?     @map("resolved_by_id") @db.Uuid
  resolutionNotes  String?     @map("resolution_notes")
  identifiedAt     DateTime    @default(now()) @map("identified_at") @db.Timestamptz(6)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks        Task[]

  @@index([organizationId], map: "idx_gaps_org")
  @@index([organizationId, domain], map: "idx_gaps_org_domain")
  @@index([organizationId, severity], map: "idx_gaps_org_severity")
  @@index([organizationId, status], map: "idx_gaps_org_status")
  @@map("compliance_gaps")
}

model ComplianceScore {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String    @unique(map: "compliance_scores_org_unique") @map("organization_id") @db.Uuid
  domainCode        String    @map("domain_code")
  score             Float
  rating            CqcRating
  calculatedAt      DateTime  @default(now()) @map("calculated_at") @db.Timestamptz(6)
  breakdown         Json?
  previousScore     Float?    @map("previous_score")
  scoreTrend        Float     @default(0) @map("score_trend")
  predictedRating   CqcRating @default(INADEQUATE) @map("predicted_rating")
  ratingConfidence  Float     @default(0) @map("rating_confidence")
  hasCriticalGap    Boolean   @default(false) @map("has_critical_gap")
  totalRequirements Int       @default(0) @map("total_requirements")
  metRequirements   Int       @default(0) @map("met_requirements")
  totalGaps         Int       @default(0) @map("total_gaps")
  criticalGaps      Int       @default(0) @map("critical_gaps")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  domainScores DomainScore[]

  @@index([domainCode], map: "idx_compliance_domain")
  @@index([organizationId], map: "idx_compliance_org")
  @@map("compliance_scores")
}

model ConsentzSyncLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  endpoint       String
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)
  recordCount    Int?     @map("record_count")
  status         String
  errorMessage   String?  @map("error_message")
  responseData   Json?    @map("response_data")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId], map: "idx_sync_log_org")
  @@map("consentz_sync_logs")
}

model CqcDomain {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  name        String
  description String
  icon        String
  color       String
  sortOrder   Int       @map("sort_order")

  cqcKloes CqcKloe[]
  kloes    Kloe[]

  @@map("cqc_domains")
}

model CqcKloeRegulation {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kloeId       String @map("kloe_id") @db.Uuid
  regulationId String @map("regulation_id") @db.Uuid
  mappingType  String @default("suggested") @map("mapping_type")

  kloe       CqcKloe       @relation(fields: [kloeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  regulation CqcRegulation @relation(fields: [regulationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([kloeId, regulationId])
  @@index([kloeId], map: "idx_cqc_kloe_reg_kloe")
  @@index([regulationId], map: "idx_cqc_kloe_reg_reg")
  @@map("cqc_kloe_regulations")
}

model CqcKloe {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String  @unique
  domainId          String  @map("domain_id") @db.Uuid
  domainType        String  @map("domain_type")
  title             String
  description       String
  sortOrder         Int     @map("sort_order")
  appliesToClinic   Boolean @default(true) @map("applies_to_clinic")
  appliesToCareHome Boolean @default(true) @map("applies_to_care_home")
  clinicGuidance    String? @map("clinic_guidance")
  careHomeGuidance  String? @map("care_home_guidance")
  weight            Float   @default(1.0)

  cqcKloeRegulations CqcKloeRegulation[]
  domain             CqcDomain           @relation(fields: [domainId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([domainId], map: "idx_cqc_kloes_domain")
  @@index([domainType], map: "idx_cqc_kloes_domain_type")
  @@map("cqc_kloes")
}

model CqcRegulation {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String  @unique
  number          String
  name            String
  description     String
  isProsecutable  Boolean @default(false) @map("is_prosecutable")
  legislation     String  @default("Health and Social Care Act 2008 (Regulated Activities) Regulations 2014")
  sortOrder       Int     @map("sort_order")

  cqcKloeRegulations CqcKloeRegulation[]

  @@map("cqc_regulations")
}

model DomainScore {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complianceScoreId String    @map("compliance_score_id") @db.Uuid
  domain            String
  score             Float     @default(0)
  maxScore          Float     @default(0) @map("max_score")
  percentage        Float     @default(0)
  status            CqcRating @default(INADEQUATE)
  previousScore     Float?    @map("previous_score")
  trend             Float     @default(0)
  totalGaps         Int       @default(0) @map("total_gaps")
  criticalGaps      Int       @default(0) @map("critical_gaps")
  highGaps          Int       @default(0) @map("high_gaps")
  mediumGaps        Int       @default(0) @map("medium_gaps")
  lowGaps           Int       @default(0) @map("low_gaps")
  totalKloes        Int       @default(0) @map("total_kloes")
  coveredKloes      Int       @default(0) @map("covered_kloes")
  calculatedAt      DateTime  @default(now()) @map("calculated_at") @db.Timestamptz(6)

  complianceScore ComplianceScore @relation(fields: [complianceScoreId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([complianceScoreId, domain])
  @@index([complianceScoreId], map: "idx_domain_scores_cs")
  @@map("domain_scores")
}

model EvidenceItem {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  title          String
  description    String?
  fileUrl        String?          @map("file_url")
  fileName       String?          @map("file_name")
  fileType       String?          @map("file_type")
  status         EvidenceStatus   @default(VALID)
  expiryDate     DateTime?        @map("expiry_date") @db.Timestamptz(6)
  domains        String[]         @default([])
  kloeCode       String?          @map("kloe_code")
  category       EvidenceCategory
  uploadedBy     String           @map("uploaded_by")
  reviewedBy     String?          @map("reviewed_by")
  reviewedAt     DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId], map: "idx_evidence_org")
  @@index([status], map: "idx_evidence_status")
  @@map("evidence_items")
}

model EvidenceRequirement {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kloeId      String           @map("kloe_id") @db.Uuid
  serviceType ServiceType      @map("service_type")
  title       String
  description String?
  category    EvidenceCategory
  sortOrder   Int              @map("sort_order")

  kloe Kloe @relation(fields: [kloeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([kloeId], map: "idx_evidence_req_kloe")
  @@map("evidence_requirements")
}

model Incident {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String         @map("organization_id") @db.Uuid
  incidentType        IncidentType   @map("incident_type")
  title               String
  description         String
  severity            Severity
  status              IncidentStatus @default(OPEN)
  patientName         String?        @map("patient_name")
  patientId           Int?           @map("patient_id")
  reportedBy          String         @map("reported_by")
  reportedAt          DateTime       @default(now()) @map("reported_at") @db.Timestamptz(6)
  resolvedAt          DateTime?      @map("resolved_at") @db.Timestamptz(6)
  resolvedBy          String?        @map("resolved_by")
  rootCause           String?        @map("root_cause")
  actionsTaken        String?        @map("actions_taken")
  lessonsLearned      String?        @map("lessons_learned")
  domains             String[]       @default([])
  consentzIncidentId  Int?           @map("consentz_incident_id")
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId], map: "idx_incidents_org")
  @@index([status], map: "idx_incidents_status")
  @@map("incidents")
}

model KloeRegulation {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kloeId       String @map("kloe_id") @db.Uuid
  regulationId String @map("regulation_id") @db.Uuid

  kloe       Kloe       @relation(fields: [kloeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  regulation Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([kloeId, regulationId])
  @@index([kloeId], map: "idx_kloe_reg_kloe")
  @@index([regulationId], map: "idx_kloe_reg_reg")
  @@map("kloe_regulations")
}

model Kloe {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String       @unique
  domainId     String       @map("domain_id") @db.Uuid
  question     String
  description  String?
  serviceTypes ServiceType[] @map("service_types")
  sortOrder    Int          @map("sort_order")

  assessmentQuestions  AssessmentQuestion[]
  evidenceRequirements EvidenceRequirement[]
  kloeRegulations      KloeRegulation[]
  domain               CqcDomain            @relation(fields: [domainId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([domainId], map: "idx_kloes_domain")
  @@map("kloes")
}

model Notification {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  userId         String?              @map("user_id") @db.Uuid
  type           NotificationType
  title          String
  message        String
  priority       NotificationPriority @default(NORMAL)
  actionUrl      String?              @map("action_url")
  actionLabel    String?              @map("action_label")
  isRead         Boolean              @default(false) @map("is_read")
  readAt         DateTime?            @map("read_at") @db.Timestamptz(6)
  emailSent      Boolean              @default(false) @map("email_sent")
  emailSentAt    DateTime?            @map("email_sent_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime?            @map("expires_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User?        @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([organizationId], map: "idx_notifications_org")
  @@index([organizationId, isRead], map: "idx_notifications_org_read")
  @@index([userId, isRead], map: "idx_notifications_user_read")
  @@map("notifications")
}

model OrganizationMember {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId     String   @map("auth_user_id")
  organizationId String   @map("organization_id") @db.Uuid
  role           UserRole
  fullName       String   @map("full_name")
  email          String
  jobTitle       String?  @map("job_title")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([authUserId], map: "idx_org_members_auth")
  @@index([organizationId], map: "idx_org_members_org")
  @@map("organization_members")
}

model Organization {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  serviceType            ServiceType @map("service_type")
  consentzClinicId       Int?      @map("consentz_clinic_id")
  cqcRegistrationNumber  String?   @map("cqc_registration_number")
  address                String?
  phone                  String?
  email                  String?
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  cqcProviderId          String?   @map("cqc_provider_id")
  cqcLocationId          String?   @map("cqc_location_id")
  cqcRegisteredName      String?   @map("cqc_registered_name")
  cqcCurrentRating       CqcRating? @map("cqc_current_rating")
  cqcLastInspection      DateTime? @map("cqc_last_inspection") @db.Timestamptz(6)
  cqcNextInspection      DateTime? @map("cqc_next_inspection") @db.Timestamptz(6)
  city                   String?
  postcode               String?
  county                 String?
  website                String?
  registeredManager      String?   @map("registered_manager")
  bedCount               Int?      @map("bed_count")
  staffCount             Int?      @map("staff_count")
  operatingHours         String?   @map("operating_hours")
  subscriptionTier       String    @default("free") @map("subscription_tier")
  subscriptionStatus     String    @default("active") @map("subscription_status")
  stripeCustomerId       String?   @map("stripe_customer_id")
  trialEndsAt            DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  onboardingComplete     Boolean   @default(false) @map("onboarding_complete")
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz(6)

  activityLogs       ActivityLog[]
  assessments        Assessment[]
  complianceGaps     ComplianceGap[]
  complianceScore    ComplianceScore?
  consentzSyncLogs   ConsentzSyncLog[]
  evidenceItems      EvidenceItem[]
  incidents          Incident[]
  notifications      Notification[]
  organizationMembers OrganizationMember[]
  policies           Policy[]
  staffMembers       StaffMember[]
  tasks              Task[]
  users              User[]

  @@map("organizations")
}

model Policy {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  title          String
  content        String?
  fileUrl        String?      @map("file_url")
  version        String       @default("1.0")
  status         PolicyStatus @default(DRAFT)
  domains        String[]     @default([])
  lastUpdated    DateTime     @default(now()) @map("last_updated") @db.Timestamptz(6)
  nextReviewDate DateTime?    @map("next_review_date") @db.Timestamptz(6)
  createdBy      String       @map("created_by")
  approvedBy     String?      @map("approved_by")
  approvedAt     DateTime?    @map("approved_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  acknowledgements PolicyAcknowledgement[]
  versions        PolicyVersion[]

  @@index([organizationId], map: "idx_policies_org")
  @@map("policies")
}

model PolicyAcknowledgement {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId String   @map("policy_id") @db.Uuid
  userId   String   @map("user_id")
  userName String   @map("user_name")
  signedAt DateTime @default(now()) @map("signed_at") @db.Timestamptz(6)

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([policyId, userId])
  @@index([policyId], map: "idx_policy_ack_policy")
  @@map("policy_acknowledgements")
}

model PolicyVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId      String   @map("policy_id") @db.Uuid
  versionNumber Int      @map("version_number")
  content       String
  changeNotes   String?  @map("change_notes")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([policyId, versionNumber])
  @@index([policyId], map: "idx_policy_versions_policy")
  @@map("policy_versions")
}

model Regulation {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String @unique
  number       Int
  name         String
  description  String
  prosecutable Boolean @default(false)

  kloeRegulations KloeRegulation[]

  @@map("regulations")
}

model StaffCredential {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  staffName       String           @map("staff_name")
  staffEmail      String?          @map("staff_email")
  consentzUserId  Int?             @map("consentz_user_id")
  credentialType  CredentialType   @map("credential_type")
  credentialName  String           @map("credential_name")
  issueDate       DateTime?        @map("issue_date") @db.Timestamptz(6)
  expiryDate      DateTime?        @map("expiry_date") @db.Timestamptz(6)
  status          CredentialStatus @default(VALID)
  referenceNumber String?          @map("reference_number")
  fileUrl         String?          @map("file_url")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([organizationId], map: "idx_staff_cred_org")
  @@map("staff_credentials")
}

model StaffMember {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  firstName              String    @map("first_name")
  lastName               String    @map("last_name")
  email                  String?
  phone                  String?
  avatarUrl              String?   @map("avatar_url")
  jobTitle               String    @map("job_title")
  staffRole              String    @default("OTHER") @map("staff_role")
  department             String?
  startDate              DateTime  @default(now()) @map("start_date") @db.Timestamptz(6)
  endDate                DateTime? @map("end_date") @db.Timestamptz(6)
  isActive               Boolean   @default(true) @map("is_active")
  contractType           String?   @default("full_time") @map("contract_type")
  registrationBody       String?   @map("registration_body")
  registrationNumber     String?   @map("registration_number")
  registrationExpiry     DateTime? @map("registration_expiry") @db.Timestamptz(6)
  dbsNumber              String?   @map("dbs_number")
  dbsCertificateDate     DateTime? @map("dbs_certificate_date") @db.Timestamptz(6)
  dbsUpdateService       Boolean   @default(false) @map("dbs_update_service")
  dbsLevel               String?   @map("dbs_level")
  hasIndemnityInsurance  Boolean   @default(false) @map("has_indemnity_insurance")
  insuranceProvider      String?   @map("insurance_provider")
  insurancePolicyNumber  String?   @map("insurance_policy_number")
  insuranceExpiry        DateTime? @map("insurance_expiry") @db.Timestamptz(6)
  rightToWorkChecked     Boolean   @default(false) @map("right_to_work_checked")
  rightToWorkDate        DateTime? @map("right_to_work_date") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  trainingRecords TrainingRecord[]

  @@index([organizationId, isActive], map: "idx_staff_members_active")
  @@index([insuranceExpiry], map: "idx_staff_members_ins_expiry")
  @@index([organizationId], map: "idx_staff_members_org")
  @@index([registrationExpiry], map: "idx_staff_members_reg_expiry")
  @@map("staff_members")
}

model Task {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  domains        String[]   @default([])
  kloeCode       String?    @map("kloe_code")
  assignedTo     String?    @map("assigned_to")
  assignedToName String?    @map("assigned_to_name")
  dueDate        DateTime?  @map("due_date") @db.Timestamptz(6)
  completedAt    DateTime?  @map("completed_at") @db.Timestamptz(6)
  source         TaskSource @default(MANUAL)
  sourceId       String?    @map("source_id")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  gapId          String?    @map("gap_id") @db.Uuid

  complianceGap ComplianceGap? @relation(fields: [gapId], references: [id], onUpdate: NoAction)
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assignedTo], map: "idx_tasks_assigned")
  @@index([gapId], map: "idx_tasks_gap")
  @@index([organizationId], map: "idx_tasks_org")
  @@index([status], map: "idx_tasks_status")
  @@map("tasks")
}

model TrainingRecord {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staffMemberId     String    @map("staff_member_id") @db.Uuid
  courseName        String    @map("course_name")
  provider          String?
  category          String    @default("mandatory")
  isMandatory       Boolean   @default(false) @map("is_mandatory")
  linkedKloes       String[]  @default([]) @map("linked_kloes")
  linkedRegulations String[]  @default([]) @map("linked_regulations")
  completedDate     DateTime  @map("completed_date") @db.Timestamptz(6)
  expiryDate        DateTime? @map("expiry_date") @db.Timestamptz(6)
  isExpired         Boolean   @default(false) @map("is_expired")
  certificateUrl    String?   @map("certificate_url")
  score             Float?
  passed            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([staffMemberId, category], map: "idx_training_category")
  @@index([expiryDate], map: "idx_training_expiry")
  @@index([staffMemberId], map: "idx_training_staff")
  @@map("training_records")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseUserId     String    @unique @map("supabase_user_id")
  email              String
  firstName          String?   @map("first_name")
  lastName           String?   @map("last_name")
  avatarUrl          String?   @map("avatar_url")
  role               UserRole  @default(STAFF_MEMBER)
  organizationId     String?   @map("organization_id") @db.Uuid
  emailNotifications Boolean   @default(true) @map("email_notifications")
  timezone           String    @default("Europe/London")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  notifications Notification[]
  organization  Organization?  @relation(fields: [organizationId], references: [id], onUpdate: NoAction)

  @@index([supabaseUserId], map: "idx_users_supabase")
  @@index([email], map: "idx_users_email")
  @@index([organizationId], map: "idx_users_org")
  @@map("users")
}

